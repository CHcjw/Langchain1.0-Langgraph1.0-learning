# .env

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# Groq API（免费，推荐）
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=xxx

# ============================================================
# 图像处理模块专用（模块19、21）
# ============================================================
#
# Groq 不支持图像处理，需要使用 OpenAI
# 如需运行图像相关示例，请设置:
OPENAI_API_KEY=xxx

# 阿里百炼
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# web_search引擎
TAVILY_API_KEY=xxx

# langsmith
# 获取地址: https://smith.langchain.com/
LANGSMITH_API_KEY=xxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langchain-course

# 阿里OSS
OSS_ACCESS_KEY_ID=xxx
OSS_ACCESS_KEY_SECRET=xxx
OSS_BUCKET=xxx

# Pinecone 向量数据库（可选，用于 RAG 高级示例）
# 获取地址: https://www.pinecone.io/
PINECONE_API_KEY=xxx